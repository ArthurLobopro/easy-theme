{
  "name": "easy-theme",
  "displayName": "Easy Theme",
  "description": "Automatically switch VSCode themes based on time of day",
  "version": "0.1.0",
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Themes",
    "Other"
  ],
  "keywords": [
    "theme",
    "scheduler",
    "automatic",
    "time",
    "dark",
    "light"
  ],
  "icon": "images/icon.png",
  "activationEvents": [
    "onStartupFinished"
  ],
  "publisher": "ArthurLobo",
  "main": "./out/extension.js",
  "contributes": {
    "configuration": {
      "properties": {
        "easy-theme.morningTheme": {
          "type": "string",
          "description": "Theme to use in the morning period."
        },
        "easy-theme.afternoonTheme": {
          "type": "string",
          "description": "Theme to use in the afternoon period."
        },
        "easy-theme.eveningTheme": {
          "type": "string",
          "description": "Theme to use in the evening/night period."
        },
        "easy-theme.morningStart": {
          "type": "number",
          "default": 6,
          "minimum": 0,
          "maximum": 23,
          "description": "Hour when the morning period starts (0–23)."
        },
        "easy-theme.afternoonStart": {
          "type": "number",
          "default": 12,
          "minimum": 0,
          "maximum": 23,
          "description": "Hour when the afternoon period starts (0–23)."
        },
        "easy-theme.eveningStart": {
          "type": "number",
          "default": 18,
          "minimum": 0,
          "maximum": 23,
          "description": "Hour when the evening period starts (0–23)."
        },
        "easy-theme.enabled": {
          "type": "boolean",
          "default": true,
          "description": "Enable or disable automatic theme switching."
        }
      }
    },
    "commands": [
      {
        "command": "easy-theme.applyNow",
        "title": "Easy Theme: Apply Theme for Current Time"
      },
      {
        "command": "easy-theme.showStatus",
        "title": "Easy Theme: Show Current Status"
      },
      {
        "command": "easy-theme.listInstalledThemes",
        "title": "Easy Theme: List Installed Themes"
      }
    ]
  },
  "scripts": {
    "vscode:prepublish": "npm run package",
    "compile": "node esbuild.js",
    "watch": "npm-run-all -p watch:*",
    "watch:esbuild": "node esbuild.js --watch",
    "watch:tsc": "tsc --noEmit --watch --project tsconfig.json",
    "package": "node esbuild.js --production"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.5.0",
    "@types/node": "^20.0.0",
    "@types/vscode": "^1.85.0",
    "npm-run-all": "^4.1.5",
    "esbuild": "^0.28.1",
    "typescript": "^5.3.0"
  }
}